{
  "expo": {
    "name": "Fractonica",
    "slug": "fractonica",
    "scheme": "fractonica",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "ios": {
      "appleTeamId": "3477AQKK6R",
      "supportsTablet": true,
      "bundleIdentifier": "com.fractonica.mobile"
    },
    "android": {
      "package": "com.fractonica.mobile"
    },
    "plugins": [
      "expo-router",
      "./plugins/with-loopback-pairing-transport",
      "./plugins/with-user-script-sandboxing-disabled"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
