{
  "name": "fractonica-workspace",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "pnpm --recursive build",
    "check": "pnpm glyph:check && pnpm --recursive check",
    "desktop:build": "pnpm --filter @fractonica/desktop bundle",
    "desktop:dev": "pnpm --filter @fractonica/desktop dev",
    "dev": "pnpm --filter @fractonica/control-center dev",
    "glyph:check": "node tools/glyph/generate-glyph-artifacts.mjs --check",
    "import:exeligmos": "pnpm --filter @fractonica/import-exeligmos start",
    "test": "pnpm --recursive test"
  }
}
