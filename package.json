{
  "name": "fractonica-workspace",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "pnpm --recursive build",
    "check": "pnpm glyph:check && pnpm --recursive check",
    "desktop:allow-local-network": "pnpm --filter @fractonica/desktop allow-local-network",
    "desktop:build": "pnpm --filter @fractonica/desktop bundle",
    "desktop:dev": "pnpm --filter @fractonica/desktop dev",
    "dev": "pnpm --filter @fractonica/control-center dev",
    "glyph:check": "node tools/glyph/generate-glyph-artifacts.mjs --check",
    "mobile:android": "pnpm mobile:native:android && pnpm --filter @fractonica/mobile run android",
    "mobile:doctor": "pnpm --filter @fractonica/mobile run doctor",
    "mobile:ios": "pnpm mobile:native:ios && pnpm --filter @fractonica/mobile run ios",
    "mobile:native": "./scripts/mobile/build-native.sh",
    "mobile:native:android": "./scripts/mobile/build-android.sh",
    "mobile:native:bindings": "./scripts/mobile/generate-bindings.sh",
    "mobile:native:ios": "./scripts/mobile/build-ios.sh",
    "mobile:start": "pnpm --filter @fractonica/mobile run start",
    "node:dev": "cargo run -p fractonica-node",
    "test": "pnpm --recursive test"
  }
}
